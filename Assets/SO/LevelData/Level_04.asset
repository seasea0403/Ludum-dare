  introAnimator: {fileID: 0}
  introImage: {fileID: 0}
  introText: I follow the old signal to find you again.
  subtitleLines:
  - text: 'I always think of that old school hallway, '
    delayAfter: 8
  - text: 'a time lost forever, '
    delayAfter: 5
  - text: with friendships I can never reclaim.
    delayAfter: 8
  - text: 'Back then, I walked home unafraid, '
    delayAfter: 8
  - text: full of endless hope for whatever came next.
    delayAfter: 8
  - text: 'The most precious thing of all was my young, fearless soul, '
    delayAfter: 8
  - text: glowing with bright signals.
    delayAfter: 8
