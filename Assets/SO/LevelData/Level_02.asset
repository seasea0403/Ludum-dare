  subtitleLines:
  - text: I miss old school hallways
    delayAfter: 3
  - text: where lost time and friendship fade.
    delayAfter: 3
  - text: I walked without fear back then,
    delayAfter: 3
  - text: hope in my heart was laid.
    delayAfter: 3
  - text: My fearless young soul
    delayAfter: 3
  - text: was the best treasure I made.
    delayAfter: 100
