--- !u!114 &1473504636
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1473504631}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb04047e6d0d8084589105a3f64e2340, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - text: 'I died in this very hospital, '
    delayAfter: 10
  - text: just a few floors above where I was born.
    delayAfter: 10
  - text: "I walked a lifetime\u2019s journey, "
    delayAfter: 10
  - text: only to return to where it all began.
    delayAfter: 10
  - text: "The only signal I couldn\u2019t let go was my cat, "
    delayAfter: 10
  - text: waiting faithfully at home.
    delayAfter: 10
  endDelay: 10
  hideOnComplete: 1
  autoPlay: 1
